{
  "tasks": {
    "dev": "deno run --allow-all --watch src/server.ts",
    "dev:http": "deno run --allow-all --watch src/server.ts --http",
    "start": "deno run --allow-all src/server.ts",
    "start:http": "deno run --allow-all src/server.ts --http",
    "test": "deno test --allow-all"
  },
  "imports": {
    "@std/": "https://deno.land/std@0.230.0/",
    "@modelcontextprotocol/sdk": "npm:@modelcontextprotocol/sdk@1.20.0",
    "@types/node": "npm:@types/node@^24.7.2",
    "express": "npm:express@5.1.0",
    "@types/express": "npm:@types/express@5.0.3",
    "zod": "npm:zod@^4.1.12"
  },
  "compilerOptions": {
    "strict": true
  }
}
